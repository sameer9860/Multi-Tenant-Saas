# ── Django core ────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:3000

# ── Database ───────────────────────────────────────────────────
# Leave blank to use SQLite (development only)
# Set to a PostgreSQL URL for production
DATABASE_URL=

# ── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_HOURS=24
JWT_REFRESH_DAYS=7

# ── API throttling ─────────────────────────────────────────────
API_THROTTLE_ANON=60/hour
API_THROTTLE_USER=1000/hour
API_THROTTLE_TOKEN=10/minute

# ── Email (SMTP) ───────────────────────────────────────────────
# Local dev with Mailhog: keep defaults below
# Production: set to your SMTP provider values
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com

# ── eSewa payment gateway ──────────────────────────────────────
ESEWA_BASE_URL=https://rc-epay.esewa.com.np/epay/main
ESEWA_VERIFY_URL=https://rc-epay.esewa.com.np/epay/transrec
ESEWA_MERCHANT_CODE=
ESEWA_USE_MOCK=False

# ── Security (production only) ─────────────────────────────────
SECURE_SSL_REDIRECT=False
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# ── Logging ────────────────────────────────────────────────────
DJANGO_LOG_LEVEL=INFO
